// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  imageUrl  String?
  createdAt DateTime @default(now())

  products  Product[]
  reviews   Review[]
  favorites Favorite[]

  role  Role    @default(CUSTOMER)
  carts Cart[]
  sales Sales[]
}

enum Role {
  CUSTOMER
  SELLER
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String?
  oldPrice    Int?
  price       Int
  imageUrl    String
  createdAt   DateTime @default(now())

  createdBy   User       @relation(fields: [createdById], references: [id])
  createdById String
  Category    Categories @relation(fields: [categoryId], references: [id])
  categoryId  Int

  reviews   Review[]
  favorites Favorite[]
  carts     Cart[]
  sales     Sales[]
}

model Sales {
  id String @id @default(cuid())

  product   Product @relation(fields: [productId], references: [id])
  productId String
  sale      String

  user         User?       @relation(fields: [userId], references: [id])
  userId       String?
  categories   Categories? @relation(fields: [categoriesId], references: [id])
  categoriesId Int?
  reviews      Review[]
  favorites    Favorite[]
  carts        Cart[]
}

model Categories {
  id       Int    @id @default(autoincrement())
  imageUrl String
  title    String

  products Product[]
  sales    Sales[]
}

model Review {
  id          String   @id @default(cuid())
  rating      Int
  description String
  createdAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  product   Product @relation(fields: [productId], references: [id])
  productId String
  sales     Sales?  @relation(fields: [salesId], references: [id])
  salesId   String?
}

model Favorite {
  id String @id @default(cuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  product   Product @relation(fields: [productId], references: [id])
  productId String
  sales     Sales?  @relation(fields: [salesId], references: [id])
  salesId   String?

  @@unique([userId, productId])
}

model Cart {
  id String @id @default(cuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  product   Product @relation(fields: [productId], references: [id])
  productId String
  sales     Sales?  @relation(fields: [salesId], references: [id])
  salesId   String?

  @@unique([userId, productId])
}
