generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ENGINEER
  MANAGER
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DECOMMISSIONED
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  INSPECTION
}

enum ScheduleType {
  BY_TIME // по календарю
  BY_USAGE // по наработке
  COMBINED
}

enum TaskStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      UserRole @default(MANAGER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks         MaintenanceTask[]
  notifications Notification[]
}

model Product {
  id           String        @id @default(uuid())
  name         String
  serialNumber String        @unique
  description  String?
  status       ProductStatus @default(ACTIVE)
  imageUrl     String?

  commissionDate     DateTime
  standartUsageHours Float    @default(1100)
  totalUsageHours    Float    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules MaintenanceSchedule[]
  tasks     MaintenanceTask[]
  reports   Report[]
}

model MaintenanceTemplate {
  id          String          @id @default(uuid())
  name        String
  description String?
  type        MaintenanceType

  estimatedHours Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules MaintenanceSchedule[]
}

model MaintenanceSchedule {
  id String @id @default(uuid())

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productId String

  template   MaintenanceTemplate @relation(fields: [templateId], references: [id])
  templateId String

  scheduleType ScheduleType

  intervalDays  Int? // если по времени
  intervalHours Float? // если по наработке

  lastExecutedAt DateTime?
  lastUsageValue Float?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks MaintenanceTask[]
}

model MaintenanceTask {
  id String @id @default(uuid())

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productId String

  schedule   MaintenanceSchedule? @relation(fields: [scheduleId], references: [id])
  scheduleId String?

  assignedTo   User?   @relation(fields: [assignedToId], references: [id])
  assignedToId String?

  status TaskStatus @default(PLANNED)

  plannedDate DateTime
  dueDate     DateTime?
  completedAt DateTime?

  usageAtCreation Float?

  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  title   String
  message String

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
}

model AuditLog {
  id       String  @id @default(uuid())
  entity   String
  entityId String
  action   String
  userId   String?
  metadata Json?

  createdAt DateTime @default(now())
}

model Report {
  id      String @id @default(uuid())
  title   String
  fileUrl String

  product   Product @relation(fields: [productId], references: [id])
  productId String
}
